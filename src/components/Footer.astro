---
import { getPortfolio, getAlternateUrl, type Locale } from '@/i18n'
import { getSectionIds } from '@/i18n/sections'

interface Props {
  lang?: Locale
}

const { lang = 'es' } = Astro.props
const content = getPortfolio(lang)
const ids = getSectionIds(lang)
const alternateUrl = getAlternateUrl(lang)

const currentYear = new Date().getFullYear()
const contactHref = lang === 'en' ? `/en/#${ids.contact}` : `/#${ids.contact}`
---

<footer class="border-t border-white/10 bg-black px-4 py-10 sm:px-6 md:px-12">
  <div
    class={`mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 font-mono text-xs tracking-[-0.36px] text-fog-gray sm:flex-row`}
  >
    <span>© {currentYear} {content.site.name}</span>
    <ul class="flex flex-wrap items-center justify-center gap-6 sm:gap-8">
      <li>
        <a href={contactHref} class="transition-colors hover:text-white">
          {content.ui.footerContact}
        </a>
      </li>
      <li>
        <a href={content.site.github} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
          GitHub
        </a>
      </li>
      <li>
        <a href={content.site.linkedin} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
          LinkedIn
        </a>
      </li>
      <li>
        <a href={alternateUrl} class="transition-colors hover:text-white">
          {content.ui.langSwitch}
        </a>
      </li>
    </ul>
  </div>
</footer>
