---
import Badge from '@/components/Badge.astro'
import SectionContainer from '@/components/SectionContainer.astro'
import SocialPill from '@/components/SocialPill.astro'
import LinkedInIcon from '@/components/icons/LinkedIn.astro'
import CinematicLayout from '@/layouts/CinematicLayout.astro'

const site = 'https://porfolio.dev/'
---

<CinematicLayout
  lang="es"
  title="Design System — Nube"
  description="Catálogo de componentes del portafolio"
  canonical={`${site}components/`}
  alternateUrl={`${site}en/`}
  alternateLang="en"
  xDefaultUrl={site}
  ogImage="/porfolio.webp"
>
  <SectionContainer sectionClass="py-44 pb-32 flex flex-col gap-y-10">
    <article class="mb-10">
      <h1 class="mb-4 text-xl font-semibold">&lt;Badge /&gt;</h1>
      <Badge>Disponible para trabajar</Badge>
    </article>

    <article class="mb-10">
      <h1 class="mb-4 text-xl font-semibold">&lt SocialPill /&gt;</h1>
      <div class="flex">
        <SocialPill href="https://www.linkedin.com/in/juandiegocalleg/">
          <LinkedInIcon class="size-4 md:size-6" />
          LinkedIn
        </SocialPill>
      </div>
    </article>
  </SectionContainer>
</CinematicLayout>
