---
const { label } = Astro.props
---

<div class="mb-12 border-b border-white/10 pb-6">
  {label && (
    <p class="font-mono-caption mb-3 uppercase text-fog-gray">
      {label}
    </p>
  )}
  <h2 class="font-display text-4xl uppercase leading-[0.9] tracking-[-1.44px] text-white md:text-5xl">
    <slot />
  </h2>
</div>
