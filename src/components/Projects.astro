---
import GitHub from './icons/GitHub.astro'
import Link from './icons/Link.astro'
import type { PortfolioContent } from '@/i18n/types'

interface Props {
  content: PortfolioContent
}

const { content } = Astro.props
const { ui } = content
---

<div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:gap-8 2xl:grid-cols-3 2xl:gap-8">
  {
    content.projects.map(({ image, title, description, tags, link, github }) => (
      <article class="paper-card group overflow-hidden transition-shadow hover:shadow-sm">
        <div class="relative overflow-hidden">
          <img
            alt={title}
            class="relative z-0 h-52 w-full object-cover object-top transition duration-500 group-hover:scale-[1.02] sm:h-56 xl:h-64 2xl:h-72"
            loading="lazy"
            src={image}
          />
        </div>
        <div class="flex flex-1 flex-col p-5 md:p-6">
          <h3 class="font-display text-xl uppercase leading-[0.9] text-white">{title}</h3>
          <ul class="mt-3 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li>
                <span class="tag-pill">{tag}</span>
              </li>
            ))}
          </ul>
          <p class="mt-4 flex-1 text-sm leading-[1.25] tracking-[-0.42px] text-ash-gray">{description}</p>
          <footer class="mt-5 flex gap-5 border-t border-white/10 pt-4">
            {github && (
              <a href={github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-medium text-fog-gray transition-colors hover:text-white">
                <GitHub class="size-4" />
                {ui.code}
              </a>
            )}
            {link && (
              <a href={link} target="_blank" rel="noopener noreferrer" class="link-accent inline-flex items-center gap-1.5 text-xs font-medium">
                <Link class="size-4" />
                {ui.live}
              </a>
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>
