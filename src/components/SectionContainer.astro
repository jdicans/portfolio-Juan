---
const { sectionClass: sectionClassName, id } = Astro.props
---

<section
  id={id}
  data-section={id}
  class:list={[
    'section-reveal',
    'section-cinematic',
    'relative',
    'scroll-m-20',
    'w-full',
    'overflow-hidden',
    sectionClassName,
  ]}
>
  <div class="relative z-10">
    <slot />
  </div>
</section>
