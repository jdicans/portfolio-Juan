---
import type { PortfolioContent } from '@/i18n/types'
import { getSectionIds } from '@/i18n/sections'

interface Props {
  content: PortfolioContent
}

const { content } = Astro.props
const { about, locale } = content
const contactId = getSectionIds(locale).contact
const contactHref = locale === 'en' ? `/en/#${contactId}` : `/#${contactId}`
const contactLabel = locale === 'en' ? 'Get in touch' : 'Escríbeme'
---

<article class="paper-card overflow-hidden">
  <div class="grid lg:grid-cols-5">
    <div class="relative lg:col-span-2">
      <img
        width="480"
        height="560"
        src="/me.jpg"
        alt={about.imageAlt}
        class="h-64 w-full object-cover object-center sm:h-80 lg:h-full lg:min-h-[420px]"
        loading="lazy"
      />
      <div class="absolute bottom-0 left-0 bg-gradient-to-t from-black via-black/50 to-transparent p-6 lg:hidden">
        <p class="font-mono-caption text-fog-gray">Nube</p>
        <p class="mt-1 font-display text-2xl uppercase text-white">Juan Diego Calleg</p>
      </div>
    </div>

    <div class="flex flex-col justify-center p-6 sm:p-8 lg:col-span-3 lg:p-10">
      <p class="hidden font-mono-caption uppercase text-fog-gray lg:block">
        Juan Diego Calleg · Nube
      </p>

      <h3 class="mt-2 font-display text-3xl uppercase leading-[0.9] text-white sm:text-4xl">
        {about.tagline}
      </h3>

      <dl class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          about.highlights.map((item) => (
            <div class="rounded-btn border border-white/10 bg-white/5 px-3 py-2.5">
              <dt class="font-mono text-[9px] uppercase tracking-[-0.36px] text-fog-gray">{item.label}</dt>
              <dd class="mt-1 text-xs font-semibold uppercase text-white">{item.value}</dd>
            </div>
          ))
        }
      </dl>

      <p class="mt-6 text-sm leading-[1.25] tracking-[-0.42px] text-ash-gray">{about.intro}</p>

      <div class="mt-6">
        <p class="font-mono-caption uppercase text-fog-gray">{about.focusTitle}</p>
        <ul class="mt-3 flex flex-wrap gap-2">
          {
            about.focusAreas.map((area) => (
              <li>
                <span class="tag-pill">{area}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <p class="mt-6 text-sm leading-[1.25] tracking-[-0.42px] text-fog-gray">{about.closing}</p>

      <a href={contactHref} class="btn-primary mt-8 w-fit">
        {contactLabel}
      </a>
    </div>
  </div>
</article>
