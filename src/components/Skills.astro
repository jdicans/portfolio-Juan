---
import type { PortfolioContent } from '@/i18n/types'

interface Props {
  content: PortfolioContent
}

const { content } = Astro.props
---

<div class="grid gap-6 sm:grid-cols-2 2xl:grid-cols-4 2xl:gap-8">
  {
    content.skills.map((group) => (
      <div class="paper-card p-6 md:p-8">
        <h3 class="font-mono-caption uppercase text-fog-gray">
          {group.label}
        </h3>
        <ul class="mt-4 flex flex-wrap gap-2">
          {group.items.map((skill) => (
            <li>
              <span class="tag-pill">{skill}</span>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
